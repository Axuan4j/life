# Spring Boot production environment variables for life-app

LIFE_DB_URL=jdbc:mysql://127.0.0.1:3306/life?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai
LIFE_DB_USERNAME=life
LIFE_DB_PASSWORD=change_me

LIFE_REDIS_HOST=127.0.0.1
LIFE_REDIS_PORT=6379
LIFE_REDIS_DATABASE=0
LIFE_REDIS_PASSWORD=

LIFE_LOG_PATH=/opt/life/logs
LIFE_LOG_MAX_HISTORY_DAYS=30
LIFE_LOG_LEVEL=INFO
LIFE_APP_LOG_LEVEL=INFO
LIFE_SPRING_WEB_LOG_LEVEL=INFO
LIFE_MYBATIS_LOG_LEVEL=INFO

LIFE_JWT_SECRET=change_me_to_a_long_random_secret

LIFE_STORAGE_ENDPOINT=http://127.0.0.1:9000
LIFE_STORAGE_ACCESS_KEY=minioadmin
LIFE_STORAGE_SECRET_KEY=minioadmin
LIFE_STORAGE_BUCKET=life-dev
